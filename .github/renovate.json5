  // Between 1AM and 6:59AM, first Friday of the month
  "schedule": ["* 1-6 1-7 * 5"],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["* 1-6 1-7 * 5"]
  },
  "ignoreDeps": ["ubuntu"]
}
